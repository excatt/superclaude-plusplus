{
  "version": "2.0",
  "rules": [
    {
      "skill": "build-fix",
      "mode": "auto",
      "triggers": {
        "prompt_patterns": [
          "error TS\\d+", "Build failed", "compile error",
          "빌드 에러", "빌드 실패", "컴파일 에러", "에러 났어", "안 돌아가", "빌드 안 돼"
        ],
        "exit_codes": [1]
      },
      "cooldown": 300
    },
    {
      "skill": "confidence-check",
      "mode": "auto",
      "triggers": {
        "prompt_patterns": [
          "implement", "create", "build",
          "구현", "만들어", "개발해", "시작하기 전에", "착수"
        ],
        "conditions": ["difficulty >= medium"]
      },
      "cooldown": 0
    },
    {
      "skill": "verify",
      "mode": "auto",
      "triggers": {
        "prompt_patterns": [
